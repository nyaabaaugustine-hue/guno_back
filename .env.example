# Database
DATABASE_URL=postgresql://user:password@localhost:5432/juno_tax

# NextAuth (REQUIRED - generate a strong random string)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-strong-random-secret-at-least-32-chars
# NEXTAUTH_URL is auto-detected in next-auth v4 from request headers.
# Only set if auto-detection fails (e.g. custom domain, reverse proxy).
# NEXTAUTH_URL=http://localhost:3000

# SSN Encryption (REQUIRED - generate a strong random key)
# Generate with: openssl rand -base64 32
SSN_ENCRYPTION_KEY=your-strong-random-key-at-least-32-chars

# Groq AI API (for AI Assistant LLM reasoning)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5

# Demo mode: set to "true" to enable demo accounts on production (Vercel) too
DEMO_MODE=true
